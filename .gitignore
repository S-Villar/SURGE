.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Project specific
# NOTE: originally a blanket `models/` rule; narrowed 2026-04-21 to only
# ignore runtime artifact trees (runs/<tag>/models/, data/**/models/), not
# the tracked `surge/model*` source packages. A bare `models/` here caused
# CI on a fresh clone to pick up `surge/models.py` while local checkouts
# loaded an untracked `surge/models/` package — see commit 6f33d89.
runs/**/models/
data/**/models/
*.joblib
results.json

# Internal / project-local trees (data-generation runbooks, per-experiment
# configs, Slurm launchers, investigative notebooks, internal design docs).
# Kept on local disks for reference; not shipped in the public v0.1.0 tree.
# Lessons extracted from these live in docs/internal/ (also ignored, but
# maintained as a separate local-only reference — back it up yourself).
docs/internal/
scripts/**/internal/
configs/internal/
examples/internal/
notebooks/**/internal/
templates/internal/

# DataGenerator batch outputs (generated data, not tracked)
examples/datagen/batch*/

# Large datasets and workflow outputs
runs/
runs

# Reference runs archive (ai4fusion-dev: local only, not committed)
data/runs/
data/datasets/M3DC1/*.csv
!data/datasets/M3DC1/*_sample.csv
data/datasets/SPARC/*.pkl
!data/datasets/SPARC/*_sample.pkl
# CFS bulk δp Parquet (~GB; build via scripts/m3dc1/build_delta_p_per_mode.py)
data/datasets/SPARC/delta_p_per_mode_cfs_sdata_complex_v2.parquet
# Local Slurm launch logs (job IDs, tmp copies)
logs/
pscratch/

# Exclude all PNGs (research plots, run figures, etc.) except the
# design-system logos we ship in data/logos/.
*.png
!data/logos/*.png

# M3DC1 interface/visualization outputs (explicitly excluded)
comprehensive_eigenmode*.png
test_*.png
eigenmode_*.png
field_reconstruction*.png
2d_field_*.png

# M3DC1 interface artifacts directory (generated outputs)
scripts/m3dc1/interfaces/artifacts/

# M3DC1 Python support code (pulled from external repo; see docs/dev/M3DC1_PYTHON_CODE.md)
notebooks/m3dc1/m3dc1_python_code/

# HHFW pickles: not shipped in public releases; keep local only under policy.
data/datasets/HHFW-NSTX/*.pkl

# Specific notebook files
notebooks/Test_Botorch_Pe_NSTX_Compare.ipynb
# Ignore HPO result pickles (heavy)
data/datasets/HHFW-NSTX/combined_hpo_results*.pkl

# Notebook outputs and checkpoints
.ipynb_checkpoints/
notebooks/*.ipynb
notebooks/*.csv

# Developer diagnostics artifacts
surge_dev_artifacts/

# Documentation files explaining changes/refactoring (keep local only)
REFACTORING_SUMMARY.md
*_REFACTORING*.md
*_CHANGES*.md

# OS files
.DS_Store

# Test artifacts and outputs
test_outputs/
test_hhfw*.py

# Documentation files (keep local only)
RUN_HHFW_TEST.md
TRAINER_COMPARISON_REPORT.md
UNIFIED_FRAMEWORK_SUMMARY.md
BRANCH_STRATEGY.md

# Slurm tee logs from scripts/m3dc1/train_*_augstyle.slurm
slurm_logs/


# Local HPC scratch links / accidental staging dirs (never public)
pscratch/
/src/
slurm_logs/
/m3dc1/

# Slurm batch logs accumulate in logs/ — already ignored via runs/ but
# logs/ is a separate convention used by scripts/m3dc1/internal/launch_*.sh
logs/

# Vendored external simulator python packages (e.g. m3dc1 unstructured)
# should never be in the public tree; users with HPC access set
# M3DC1_PYTHON_PATH if they need eigenmode_features' optional import.
notebooks/**/m3dc1_python_code/

# Sphinx autosummary regenerates these on every build.
docs/_build/
docs/api_reference/generated/

# Legacy / shadow `surge/models/` package directory. The canonical
# module is the tracked `surge/models.py`; the local `surge/models/`
# directory is an older/alternative layout kept on some checkouts.
# Keeping it ignored is what avoids the CI vs local collision (see
# commits 6f33d89 and ead0177 for the bug and fix).
/surge/models/
